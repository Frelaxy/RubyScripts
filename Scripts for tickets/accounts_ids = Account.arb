accounts_ids = Account.where.not(status: :deleted).ids
counter = 1
account_changed = false

accounts_ids.map do |account_id|
  account = Account.find(account_id)
  puts "Обрабатывается аккаунт #{counter} из #{accounts_ids.count} | id: #{account_id} | номер: #{account.phone}"
  if !account.phone.nil?
    phone = account.phone
    if phone.include? "-"
      phone.gsub!('-','')
      puts "символ '-' удалён"
      account_changed = true
    end
    if phone.include? "("
      phone.gsub!('(','')
      puts "символ '(' удалён"
      account_changed = true
    end
    if phone.include? ")"
      phone.gsub!(')','')
      puts "символ ')' удалён"
      account_changed = true
    end
    if phone.include? " "
      phone.gsub!(' ', '')
      puts "пробелы удалены"
      account_changed = true
    end
    if account_changed == true
      puts "номер был изменён на #{account.phone}"
      begin 
        account.save!
      rescue => e
        puts 'Аккаунт не изменён, так как была ошибка'
      end
    else
      puts "номер не был изменён"
    end
    account_changed = false
  end
  counter += 1
end