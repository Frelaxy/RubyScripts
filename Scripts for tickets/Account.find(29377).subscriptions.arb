subs_ids = [57528, 56229, 56228, 56227, 56226, 56225, 53700]
subs_ids = [56229, 56228, 56227, 56226, 56225, 53700]
subs_ids.each do |sub_id|
  subscription = Subscription.find(sub_id)
  application = Application.find_by(subscription_id: subscription.id)
  origin = application.origin
  origin.external_id = origin.external_id.chomp("_broken")
  origin.microsoft_order_id = origin.microsoft_order_id.chomp("_broken")
  origin.save!
  application.update(service_status: :running)
  subscription.update(status: :active)
  Note.where(noteable_type: "Subscription", noteable_id: subscription.id).last.delete
end


